{
  "name": "account-switcher-for-claude-code",
  "displayName": "Account Switcher for Claude Code",
  "description": "Switch between multiple Claude Code accounts in VS Code / code-server without logging out. Unofficial: snapshots ~/.claude and ~/.claude.json into named profiles, with timestamped backups, validation and automatic rollback.",
  "version": "0.5.0",
  "publisher": "faisalsannan",
  "license": "MIT",
  "author": "Faisal Sannan",
  "icon": "images/icon.png",
  "galleryBanner": { "color": "#2b2a33", "theme": "dark" },
  "homepage": "https://github.com/FaisalSannan/account-switcher-for-claude-code#readme",
  "sponsor": {
    "url": "https://github.com/sponsors/FaisalSannan"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FaisalSannan/account-switcher-for-claude-code.git"
  },
  "bugs": {
    "url": "https://github.com/FaisalSannan/account-switcher-for-claude-code/issues"
  },
  "engines": { "vscode": "^1.92.0" },
  "categories": ["Other"],
  "keywords": [
    "claude",
    "claude code",
    "vscode",
    "account switcher",
    "profile switcher",
    "multi-account",
    "switch accounts",
    "anthropic",
    "code-server"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      { "command": "claudeProfileSwitcher.importCurrent", "title": "Claude Profile Switcher: Import Current Claude Account" },
      { "command": "claudeProfileSwitcher.createEmpty", "title": "Claude Profile Switcher: Create Empty Profile" },
      { "command": "claudeProfileSwitcher.switchProfile", "title": "Claude Profile Switcher: Switch Official Claude Account" },
      { "command": "claudeProfileSwitcher.syncActive", "title": "Claude Profile Switcher: Save Current State to Active Profile" },
      { "command": "claudeProfileSwitcher.backupNow", "title": "Claude Profile Switcher: Backup Current Claude State" },
      { "command": "claudeProfileSwitcher.restoreLastBackup", "title": "Claude Profile Switcher: Restore Last Backup" },
      { "command": "claudeProfileSwitcher.showStatus", "title": "Claude Profile Switcher: Show Status" },
      { "command": "claudeProfileSwitcher.openProfilesFolder", "title": "Claude Profile Switcher: Open Profiles Folder" },
      { "command": "claudeProfileSwitcher.deleteProfile", "title": "Claude Profile Switcher: Delete Profile" }
    ],
    "configuration": {
      "title": "Account Switcher for Claude Code",
      "properties": {
        "claudeProfileSwitcher.profilesRoot": {
          "type": "string",
          "default": "",
          "description": "Folder for saved Claude profiles. Empty means ~/.claude-profiles."
        },
        "claudeProfileSwitcher.activeClaudeDir": {
          "type": "string",
          "default": "",
          "description": "Active Claude config dir. Empty means ~/.claude."
        },
        "claudeProfileSwitcher.activeClaudeJson": {
          "type": "string",
          "default": "",
          "description": "Active Claude JSON file. Empty means ~/.claude.json."
        },
        "claudeProfileSwitcher.reloadAfterSwitch": {
          "type": "boolean",
          "default": true,
          "description": "Reload the VS Code/code-server window automatically after a profile switch so the official Claude extension rereads the active profile."
        },
        "claudeProfileSwitcher.maxBackups": {
          "type": "number",
          "default": 25,
          "minimum": 0,
          "description": "Maximum number of timestamped backups to keep in <profilesRoot>/_backups (oldest pruned first). 0 disables pruning."
        }
      }
    },
    "menus": {
      "commandPalette": [
        { "command": "claudeProfileSwitcher.importCurrent" },
        { "command": "claudeProfileSwitcher.createEmpty" },
        { "command": "claudeProfileSwitcher.switchProfile" },
        { "command": "claudeProfileSwitcher.syncActive" },
        { "command": "claudeProfileSwitcher.backupNow" },
        { "command": "claudeProfileSwitcher.restoreLastBackup" },
        { "command": "claudeProfileSwitcher.showStatus" },
        { "command": "claudeProfileSwitcher.openProfilesFolder" },
        { "command": "claudeProfileSwitcher.deleteProfile" }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node test/core.test.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.92.0",
    "typescript": "^5.5.4",
    "@vscode/vsce": "^3.2.1"
  }
}
